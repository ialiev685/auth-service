{
  "name": "auth-service",
  "version": "1.0.0",
  "main": "app.js",
  "repository": "git@github.com:ialiev685/auth-service.git",
  "author": "Ilfat Aliev <ialiev685@gmail.com>",
  "license": "MIT",
  "scripts": {
    "build": "yarn clean && tsc",
    "dev": "tsx watch --env-file=.env.dev src/app.ts",
    "dev:docker": "RUNNING_IN_DOCKER=true tsx watch --env-file=.env.dev src/app.ts",
    "start": "yarn build && node dist/app.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist",
    "migrate:create": "tsx src/database/migrate.ts create --prefix TIMESTAMP --folder src/database/migrations --name",
    "seed:create": "tsx src/database/seed.ts create --prefix TIMESTAMP --folder src/database/seeds --name",
    "premigrate": "yarn build",
    "premigrate:pending": "yarn build",
    "premigrate:down": "yarn build",
    "migrate": "node --env-file=.env.${ENV:-dev} dist/database/migrate.js up",
    "migrate:pending": "node --env-file=.env.${ENV:-dev} dist/database/migrate.js pending",
    "migrate:down": "node --env-file=.env.${ENV:-dev} dist/database/migrate.js down --name",
    "seed:up": "node --env-file=.env.${ENV:-dev} dist/database/seed.js up",
    "seed:down": "node --env-file=.env.${ENV:-dev} dist/database/seed.js down --name"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@types/json-schema": "^7.0.15",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.4",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "typebox": "^1.1.19",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "umzug": "^3.8.2"
  },
  "packageManager": "yarn@1.22.22"
}
